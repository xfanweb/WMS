.container {
	height: 100%;
	padding: 16rpx 16rpx 16rpx;
	box-sizing: border-box;
	width: 100%;
}
.scantext {
	font-size: 36rpx;
	margin-left: 24rpx;
}
.center {
	text-align: center;
}
.end {
	position: fixed;
	margin: 0 auto;
	left: 0;
	right: 0;
	width: 83% !important;
}
.admin {
	bottom: 350rpx;
}
.scan {
	bottom: 180rpx;
}
.copy {
	position: fixed;
	margin: 0 auto;
	left: 0;
	right: 0;
	font-size: 28rpx;
	bottom: 70rpx;
}
.by {
	position: fixed;
	margin: 0 auto;
	left: 0;
	right: 0;
	color: #909399;
	font-size: 24rpx;
	bottom: 30rpx;
	justify-content: center;
}

/* 自定义样式 */
.el-button {
	color: #fff;
	background-color: #409eff;
	border-color: #409eff;
	display: inline-block;
	line-height: 1;
	white-space: nowrap;
	cursor: pointer;
	background: #fff;
	border: 1px solid #dcdfe6;
	-webkit-appearance: none;
	text-align: center;
	box-sizing: border-box;
	outline: none;
	margin: 0;
	transition: .1s;
	font-weight: 500;
	-moz-user-select: none;
	-webkit-user-select: none;
	-ms-user-select: none;
	padding: 12px 20px;
	font-size: 14px;
	border-radius: 4px;
}
.el-card {
	box-shadow: 0 2px 12px 0 rgb(0 0 0 / 10%);
	width: auto;
	border-radius: 4px;
	border: 1px solid #ebeef5;
	padding: 20px;
	background-color: #fff;
	overflow: hidden;
	color: #303133;
	transition: .3s;
}
.flex {
	display: flex;
	align-items: center;
}
.mgt12 {
	margin-top: 12rpx !important;
}
.mgr16 {
	margin-right: 16rpx !important;
}
.mgl8 {
