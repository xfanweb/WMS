.container {
	height: 100%;
    padding: 16rpx 16rpx 16rpx;
    box-sizing: border-box;
    width: 100%;
}
.flex{
	display: flex;
	align-items: center;
}
.scanimg{
	height: 64rpx;
	width: 64rpx;
}
.scantext{
	font-size: 36rpx;
	margin-left: 24rpx;
}
.center{
	text-align: center;
}
/* 自定义样式 */
.el-button {
	color: #fff;
	background-color: #409eff;
	border-color: #409eff;
    display: inline-block;
    line-height: 1;
    white-space: nowrap;
    cursor: pointer;
    background: #fff;
    border: 1px solid #dcdfe6;
    -webkit-appearance: none;
    text-align: center;
    box-sizing: border-box;
    outline: none;
    margin: 0;
    transition: .1s;
    font-weight: 500;
    -moz-user-select: none;
    -webkit-user-select: none;
    -ms-user-select: none;
    padding: 12px 20px;
    font-size: 14px;
    border-radius: 4px;
}
.el-card {
	box-shadow: 0 2px 12px 0 rgb(0 0 0 / 10%);
	width: auto;
    border-radius: 4px;
    border: 1px solid #ebeef5;
	padding: 20px;
    background-color: #fff;
    overflow: hidden;
    color: #303133;
    transition: .3s;
}
/* UI 样式 */

