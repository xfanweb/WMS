<view class="container"><block wx:for="{{data}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="el-card"><view class="flex mgt12 p3"><label class="_span">品牌：</label><view class="text">{{item.brand}}</view></view><view class="flex mgt12 p3"><label class="_span">类型：</label><view class="text">{{item.type}}</view></view><view class="flex mgt12 p3"><label class="_span">型号：</label><view class="text">{{item.model}}</view></view><view class="flex mgt12 p3"><label class="_span">编号：</label><view class="text">{{item.serialNo}}</view></view><view class="flex mgt12 p3"><label class="_span">姓名：</label><view class="text"><u-input bind:input="__e" vue-id="{{'3db16520-1-'+index}}" type="text" border="bottom" clearable="{{true}}" placeholder="请输入姓名" maxlength="4" disabled="{{input}}" value="{{name}}" data-event-opts="{{[['^input',[['__set_model',['','name','$event',[]]]]]]}}" bind:__l="__l"></u-input></view></view><view class="flex mgt12 p3"><label class="_span">手机号：</label><view class="text"><u-input bind:input="__e" vue-id="{{'3db16520-2-'+index}}" type="number" border="bottom" clearable="{{true}}" placeholder="请输入手机号" disabled="{{input}}" maxlength="11" value="{{phone}}" data-event-opts="{{[['^input',[['__set_model',['','phone','$event',[]]]]]]}}" bind:__l="__l"></u-input></view></view><view class="flex mgt12 p3"><label class="_span">状态：</label><view class="flex"><view class="mgr16">{{StatusContent==false?"未借出":"已借出"}}</view><u-switch vue-id="{{'3db16520-3-'+index}}" activeColor="#5ac725" inactiveColor="#f56c6c" disabled="{{status}}" value="{{value}}" data-event-opts="{{[['^change',[['change']]],['^input',[['__set_model',['','value','$event',[]]]]]]}}" bind:change="__e" bind:input="__e" bind:__l="__l"></u-switch></view></view></view></block></view>