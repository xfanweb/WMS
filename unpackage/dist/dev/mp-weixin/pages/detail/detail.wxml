<view class="container"><block wx:for="{{stock}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="el-card"><view class="flex mgt12 pd3"><label class="_span">品牌：</label><view class="text">{{item.brand}}</view></view><view class="flex mgt12 pd3"><label class="_span">类型：</label><view class="text">{{item.type}}</view></view><view class="flex mgt12 pd3"><label class="_span">型号：</label><view class="text">{{item.model}}</view></view><view class="flex mgt12 pd3"><label class="_span">编号：</label><view class="text">{{item.serialNo}}</view></view><view class="flex mgt12 pd3"><label class="_span">姓名：</label><view class="text"><u-input bind:input="__e" vue-id="{{'3db16520-1-'+index}}" type="text" border="bottom" clearable="{{true}}" placeholder="请输入姓名" maxlength="4" disabled="{{input}}" value="{{name}}" data-event-opts="{{[['^input',[['__set_model',['','name','$event',[]]]]]]}}" bind:__l="__l"></u-input></view></view><view class="flex mgt12 pd3"><label class="_span">手机号：</label><view class="text"><u-input bind:input="__e" vue-id="{{'3db16520-2-'+index}}" type="number" border="bottom" clearable="{{true}}" placeholder="请输入手机号" disabled="{{input}}" maxlength="11" value="{{phone}}" data-event-opts="{{[['^input',[['__set_model',['','phone','$event',[]]]]]]}}" bind:__l="__l"></u-input></view></view><view class="flex mgt12 pd3"><label class="_span">状态：</label><view class="flex"><view class="mgr16">{{StatusContent==false?"未借出":"已借出"}}</view><u-switch vue-id="{{'3db16520-3-'+index}}" activeColor="#5ac725" inactiveColor="#f56c6c" disabled="{{status}}" value="{{value}}" data-event-opts="{{[['^change',[['change']]],['^input',[['__set_model',['','value','$event',[]]]]]]}}" bind:change="__e" bind:input="__e" bind:__l="__l"></u-switch></view></view></view></block><view class="el-card mgt32 record-box" style="width:auto;"><u-scroll-list vue-id="3db16520-4" bind:__l="__l" vue-slots="{{['default']}}"><uni-table vue-id="{{('3db16520-5')+','+('3db16520-4')}}" bind:__l="__l" vue-slots="{{['default']}}"><uni-tr vue-id="{{('3db16520-6')+','+('3db16520-5')}}" bind:__l="__l" vue-slots="{{['default']}}"><uni-th vue-id="{{('3db16520-7')+','+('3db16520-6')}}" align="center" bind:__l="__l" vue-slots="{{['default']}}">姓名</uni-th><uni-th vue-id="{{('3db16520-8')+','+('3db16520-6')}}" align="left" bind:__l="__l" vue-slots="{{['default']}}">手机号</uni-th><uni-th vue-id="{{('3db16520-9')+','+('3db16520-6')}}" align="left" bind:__l="__l" vue-slots="{{['default']}}">时间</uni-th><uni-th vue-id="{{('3db16520-10')+','+('3db16520-6')}}" align="center" bind:__l="__l" vue-slots="{{['default']}}">状态</uni-th></uni-tr><block wx:for="{{record}}" wx:for-item="item" wx:for-index="index" wx:key="index"><uni-tr vue-id="{{('3db16520-11-'+index)+','+('3db16520-5')}}" bind:__l="__l" vue-slots="{{['default']}}"><uni-td vue-id="{{('3db16520-12-'+index)+','+('3db16520-11-'+index)}}" bind:__l="__l" vue-slots="{{['default']}}">{{item.name}}</uni-td><uni-td vue-id="{{('3db16520-13-'+index)+','+('3db16520-11-'+index)}}" bind:__l="__l" vue-slots="{{['default']}}">{{item.phone}}</uni-td><uni-td vue-id="{{('3db16520-14-'+index)+','+('3db16520-11-'+index)}}" bind:__l="__l" vue-slots="{{['default']}}">{{item.time}}</uni-td><uni-td vue-id="{{('3db16520-15-'+index)+','+('3db16520-11-'+index)}}" bind:__l="__l" vue-slots="{{['default']}}">{{item.status}}</uni-td></uni-tr></block></uni-table></u-scroll-list></view></view>